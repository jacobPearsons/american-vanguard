// ============================================
// AVI - University Admissions Platform Prisma Schema
// Transformed from employment platform to university admissions
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id              Int       @id @default(autoincrement())
  clerkId         String    @unique
  email           String    @unique
  name            String?
  firstName       String?
  lastName        String?
  profileImage    String?
  phone           String?
  
  // Profile Information
  dateOfBirth     DateTime?
  address         String?
  city            String?
  country         String?
  nationality    String?
  
  // Account Status
  isVerified      Boolean   @default(false)
  emailVerified   Boolean   @default(false)
  
  // English Proficiency Test
  englishTestScore     Int?
  englishTestDate      DateTime?
  englishTestLevel     EnglishLevel? @default(BEGINNER)
  
  // Subscription/Tier
  tier            String    @default("Free")
  credits         String    @default("10")
  
  // Legacy: Google Drive resource ID for workflows
  googleResourceId String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  profile         UserProfile?
  resume          Resume?
  applications    AdmissionApplication[]
  testResults     EnglishTestResult[]
  notifications  Notification[]
  notificationPreferences NotificationPreferences?
}

// ============================================
// USER PROFILE
// ============================================

model UserProfile {
  id              Int       @id @default(autoincrement())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [clerkId])
  
  // Personal Info
  summary         String?   @db.Text
  skills          String[]  // Stored as array of strings
  
  // Education
  education       Education[]
  
  // Work History (for graduate applications)
  workHistory     WorkExperience[]
  
  // Languages
  languages       LanguageSkill[]
  
  // Location Preferences
  remoteWork      Boolean   @default(false)
  relocate        Boolean   @default(false)
  preferredLocations String[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Education {
  id              Int           @id @default(autoincrement())
  profileId       Int
  profile         UserProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  institution     String
  degree          String
  fieldOfStudy    String?
  startDate       DateTime
  endDate         DateTime?
  isCurrent       Boolean       @default(false)
  grade           String?
  description     String?       @db.Text
}

model WorkExperience {
  id              Int           @id @default(autoincrement())
  profileId       Int
  profile         UserProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  companyName     String
  jobTitle        String
  location        String?
  startDate       DateTime
  endDate         DateTime?
  isCurrent       Boolean       @default(false)
  description     String?       @db.Text
}

model LanguageSkill {
  id              Int           @id @default(autoincrement())
  profileId       Int
  profile         UserProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  language        String
  proficiency     LanguageProficiency
}

// ============================================
// RESUME / CV
// ============================================

model Resume {
  id              Int         @id @default(autoincrement())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [clerkId])
  
  fileName        String
  fileUrl         String
  fileType        String      // pdf, doc, docx
  fileSize        Int         // in bytes
  
  // Parsed Information
  parsedData      Json?       // Extracted text, skills, experience
  
  // Status
  isUploaded      Boolean     @default(false)
  isVerified      Boolean     @default(false)
  uploadedAt      DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============================================
// ENGLISH PROFICIENCY TEST
// ============================================

enum EnglishLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  NATIVE
}

enum LanguageProficiency {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  ADVANCED
  NATIVE
}

model EnglishTestQuestion {
  id              Int         @id @default(autoincrement())
  
  // Question Content
  question        String      @db.Text
  questionType    QuestionType
  difficulty      QuestionDifficulty
  
  // Options (for multiple choice)
  options         Json?       // Array of options
  
  // Correct Answer
  correctAnswer   String
  explanation     String?     @db.Text
  
  // Category
  category        TestCategory
  
  // Points
  points          Int         @default(1)
  
  // Active
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
}

enum QuestionType {
  READING
  WRITING
  LISTENING
  SPEAKING
  GRAMMAR
  VOCABULARY
  MULTIPLE_CHOICE
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum TestCategory {
  GRAMMAR
  VOCABULARY
  READING
  WRITING
  LISTENING
  SPEAKING
  COMPREHENSION
}

model EnglishTestResult {
  id              Int             @id @default(autoincrement())
  userId          String
  user            User            @relation(fields: [userId], references: [clerkId])
  
  // Test Details
  testType        TestType
  score           Int
  totalQuestions  Int
  correctAnswers  Int
  duration        Int             // in seconds
  
  // Breakdown
  breakdown       Json?           // Score by category
  
  // Level
  level           EnglishLevel
  
  // Status
  passed          Boolean
  completedAt     DateTime        @default(now())
  
  // Certificate
  certificateUrl  String?
}

enum TestType {
  PLACEMENT
  CERTIFICATION
  SKILLS_ASSESSMENT
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id              Int             @id @default(autoincrement())
  userId          String
  user            User            @relation(fields: [userId], references: [clerkId])
  
  // Content
  title           String
  message         String          @db.Text
  type            NotificationType
  
  // Data
  data            Json?
  link            String?
  
  // Status
  isRead          Boolean         @default(false)
  readAt          DateTime?
  
  createdAt       DateTime        @default(now())
}

model NotificationPreferences {
  id                    Int       @id @default(autoincrement())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [clerkId])
  
  // Email Notifications
  emailAdmissionUpdates Boolean   @default(true)
  emailApplicationStatus Boolean  @default(true)
  emailDeadlines        Boolean   @default(true)
  emailNewFeatures      Boolean   @default(true)
  emailMarketing        Boolean   @default(false)
  
  // In-App Notifications
  pushAdmissionUpdates Boolean   @default(true)
  pushApplicationStatus Boolean   @default(true)
  pushDeadlines        Boolean   @default(true)
  pushMessages          Boolean   @default(true)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

enum NotificationType {
  ADMISSION_RECEIVED
  ADMISSION_ACCEPTED
  ADMISSION_REJECTED
  ADMISSION_WAITLISTED
  DOCUMENT_REQUESTED
  INTERVIEW_SCHEDULED
  DECISION_MADE
  ENROLLMENT_DEADLINE
  PROFILE_VIEWED
  MESSAGE
  ENGLISH_TEST_INVITE
}

// ============================================
// UNIVERSITY ADMISSIONS
// ============================================

enum AdmissionType {
  UNDERGRADUATE
  GRADUATE
  TRANSFER
  INTERNATIONAL
  CERTIFICATE
  ONLINE
}

enum AdmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUESTED
  INTERVIEW_SCHEDULED
  ACCEPTED
  REJECTED
  WAITLISTED
  DEFERRED
  ENROLLED
  ENROLLMENT_COMPLETE
}

enum ApplicationTerm {
  FALL_2025
  SPRING_2026
  SUMMER_2026
  FALL_2026
  SPRING_2027
}

enum AdmissionsStage {
  PROGRAM_DISCOVERY
  PROGRAM_SELECTION
  APPLICATION_SUBMITTED
  DOCUMENT_REVIEW
  ENTRANCE_EXAM
  INTERVIEW
  ADMISSION_DECISION
  ENROLLMENT
  ORIENTATION
  CLASSES_BEGIN
}

model AdmissionApplication {
  id                Int             @id @default(autoincrement())
  
  // User reference
  userId            String
  user              User            @relation(fields: [userId], references: [clerkId])
  
  // Application Type
  admissionType     AdmissionType
  applicationTerm   ApplicationTerm
  
  // Admissions Stage (for pipeline tracking)
  currentStage      AdmissionsStage @default(PROGRAM_DISCOVERY)
  
  // Personal Information
  firstName         String
  lastName          String
  email             String
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  
  // Address
  currentAddress    String?
  city              String?
  state             String?
  country           String?
  postalCode        String?
  
  // Citizenship
  citizenship       String?
  isInternational   Boolean         @default(false)
  
  // Academic Background - High School (Undergraduate)
  highSchoolName    String?
  highSchoolCountry String?
  highSchoolGPA     Float?
  satScore          Int?
  actScore          Int?
  
  // Academic Background - Undergraduate (Graduate)
  undergradSchool   String?
  undergradDegree   String?
  undergradMajor    String?
  undergradGPA      Float?
  greScore          Int?
  gmatScore        Int?
  
  // Test Scores
  toeflScore       Int?
  ieltsScore       Float?
  
  // Program Selection
  programOfInterest String?
  majorFirstChoice  String?
  majorSecondChoice String?
  
  // Documents
  hasTranscript     Boolean         @default(false)
  hasRecommendation Boolean         @default(false)
  hasEssay          Boolean         @default(false)
  hasTestScores     Boolean         @default(false)
  
  // Essay/Personal Statement
  essayTopic        String?         @db.Text
  essayContent      String?         @db.Text
  
  // Additional Information
  extracurriculars  String?         @db.Text
  workExperience    String?         @db.Text
  
  // Financial Aid
  requestFinancialAid Boolean      @default(false)
  scholarshipInterest  Boolean    @default(false)
  
  // Status
  status            AdmissionStatus @default(DRAFT)
  submissionDate    DateTime?
  lastUpdated       DateTime        @updatedAt
  
  // Review Information
  reviewedBy        String?
  reviewNotes       String?         @db.Text
  reviewDate        DateTime?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

// ============================================
// UNIVERSITY PROGRAMS (Catalog)
// ============================================

model Program {
  id                Int             @id @default(autoincrement())
  
  // Program Details
  name              String
  slug              String          @unique
  description       String?         @db.Text
  shortDescription  String?
  
  // Type & Level
  programType       AdmissionType
  degreeLevel       String          // Bachelor's, Master's, PhD, Certificate
  
  // Department
  department        String?
  school            String?
  
  // Duration
  duration          String?         // e.g., "4 years", "2 years"
  durationWeeks     Int?
  
  // Requirements
  requirements      String?         @db.Text
  minimumGPA        Float?
  requiresGRE       Boolean         @default(false)
  requiresGMAT      Boolean         @default(false)
  
  // Costs
  tuitionDomestic   Decimal?        @db.Decimal(10, 2)
  tuitionInternational Decimal?    @db.Decimal(10, 2)
  applicationFee    Decimal?        @default(0)
  
  // Availability
  isActive          Boolean         @default(true)
  isFeatured        Boolean         @default(false)
  acceptsApplications Boolean       @default(true)
  
  // Terms
  availableTerms   ApplicationTerm[]
  
  // Stats
  applicationsCount Int             @default(0)
  acceptanceRate    Float?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

// ============================================
// FACULTY & DEPARTMENTS
// ============================================

model Department {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  school      String
  description String?   @db.Text
  faculty     Faculty[]
  courses     Course[]
  announcements Announcement[]
  materials     LibraryMaterial[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Faculty {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  title           String
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  photoUrl        String?
  bio             String?   @db.Text
  researchArea    String?
  office          String?
  officeHours     String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  courses         Course[]
  publications    Publication[]
}

// ============================================
// COURSES & REGISTRATION
// ============================================

model Course {
  id              Int       @id @default(autoincrement())
  code            String
  name            String
  slug            String    @unique
  description     String?   @db.Text
  credits         Int       @default(3)
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  schedule        Json?
  maxCapacity     Int       @default(50)
  enrolledCount  Int       @default(0)
  prerequisites   Json?
  isActive        Boolean   @default(true)
  semester        String
  academicYear    String
  instructorId    Int?
  instructor      Faculty?  @relation(fields: [instructorId], references: [id])
  syllabus        String?   @db.Text
  facilityTags    String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  registrations   StudentRegistration[]
  grades          Grade[]
  materials       LibraryMaterial[]
  announcements   Announcement[]
  forumThreads    ForumThread[]
}

model StudentRegistration {
  id              Int       @id @default(autoincrement())
  studentId       String
  courseId        Int
  course          Course    @relation(fields: [courseId], references: [id])
  status          RegStatus @default(ENROLLED)
  semester        String
  academicYear    String
  enrolledAt      DateTime  @default(now())
  droppedAt       DateTime?
  
  @@unique([studentId, courseId, academicYear, semester])
}

enum RegStatus {
  ENROLLED
  DROPPED
  COMPLETED
}

model Publication {
  id          Int       @id @default(autoincrement())
  title       String
  journal     String?
  year        Int
  url         String?
  facultyId   Int
  faculty     Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Announcement {
  id            Int               @id @default(autoincrement())
  title         String
  content       String            @db.Text
  type          AnnouncementType
  departmentId  Int?
  department    Department?       @relation(fields: [departmentId], references: [id])
  courseId      Int?
  course        Course?           @relation(fields: [courseId], references: [id])
  isPinned      Boolean           @default(false)
  isActive      Boolean           @default(true)
  publishedAt   DateTime          @default(now())
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum AnnouncementType {
  GENERAL
  DEPARTMENT
  DEADLINE
}

model Grade {
  id            Int       @id @default(autoincrement())
  studentId     String
  courseId      Int
  course        Course    @relation(fields: [courseId], references: [id])
  score         Int
  grade         String
  semester      String
  academicYear  String
  createdAt     DateTime  @default(now())
  
  @@unique([studentId, courseId, semester, academicYear])
}

// ============================================
// LEGACY: Connection Models (for backward compatibility)
// These models can be removed once connection/workflow pages are removed
// ============================================

model DiscordWebhook {
  id              Int          @id @default(autoincrement())
  userId          String
  webhookId       String
  channelId       String?
  guildId         String?
  guildName       String?
  name            String?
  url             String?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Connection {
  id                Int            @id @default(autoincrement())
  userId            String
  type              ConnectionType
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  metadata          Json?
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum ConnectionType {
  DISCORD
  SLACK
  NOTION
  GOOGLE
}

model Workflow {
  id              Int           @id @default(autoincrement())
  userId          String
  name            String
  description     String?
  isActive        Boolean       @default(true)
  
  // JSON structure for workflow nodes
  nodes           Json?
  edges           Json?
  
  // Google integration
  googleResourceId String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============================================
// ENUMS
// ============================================

enum AvailabilityType {
  IMMEDIATELY
  TWO_WEEKS
  ONE_MONTH
  TWO_MONTHS
  NOT_AVAILABLE
}

enum SalaryPeriod {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model LibraryMaterial {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?   @db.Text
  fileUrl       String
  fileType      String
  courseId      Int
  course        Course    @relation(fields: [courseId], references: [id])
  category      String
  departmentId  Int
  department    Department @relation(fields: [departmentId], references: [id])
  uploadedBy    String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Payment {
  id            Int       @id @default(autoincrement())
  amount        Float
  studentId     String
  description    String?
  reference     String    @unique
  status        String    @default("pending")
  paymentType   String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ForumThread {
  id          Int         @id @default(autoincrement())
  courseId    Int?
  course      Course?     @relation(fields: [courseId], references: [id])
  title       String
  content     String      @db.Text
  authorId    String
  authorName  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isPinned    Boolean     @default(false)
  isLocked    Boolean     @default(false)
  posts       ForumPost[]
}

model ForumPost {
  id          Int         @id @default(autoincrement())
  threadId    Int
  thread      ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content     String      @db.Text
  authorId    String
  authorName  String
  createdAt   DateTime    @default(now())
}
